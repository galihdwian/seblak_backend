{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm dlx esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --log-level=silent || echo 'Build finished'",
    "start": "node dist/index.js",
    "generate-model": "npx sequelize-auto -o \"./src/models\" -d bky_seblak -h localhost -u root -p 3307 -x admin -l ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "joi": "^17.13.3",
    "multer": "1.4.5-lts.2",
    "mysql2": "^3.17.0",
    "sequelize": "^6.37.7",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/express": "^4.17.21",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "bun-types": "latest",
    "sequelize-auto": "^0.8.8",
    "sequelize-cli": "^6.6.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "module": "src/index.js"
}