{
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "module": "commonjs",
    "target": "ES2020"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/modules_save"]
}
